FROM golang:1.23-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
COPY main.go ./
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/seatalk-callback .

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=build /out/seatalk-callback /app/seatalk-callback

ENV PORT=8000

EXPOSE 8000
ENTRYPOINT ["/app/seatalk-callback"]
